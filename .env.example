# EthervoxAI Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# GitHub tokens for anonymous bug reporting
# Create fine-grained personal access tokens at: https://github.com/settings/tokens
# Required permissions: public_repo (issues:write)

# Platform-specific tokens (recommended for different repositories)
ETHERVOX_GITHUB_TOKEN_ANDROID=your_android_token_here
ETHERVOX_GITHUB_TOKEN_DESKTOP=your_desktop_token_here

# Generic fallback token (if platform-specific not set)
ETHERVOX_GITHUB_TOKEN=your_generic_token_here
